<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Практична робота №16\nSQLite vs ContentProvider"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="16dp"/>

        <EditText
            android:id="@+id/editName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введіть ім'я"/>

        <Button
            android:id="@+id/buttonSaveSQLite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Зберегти напряму в SQLite"/>

        <Button
            android:id="@+id/buttonSaveProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Зберегти через ContentProvider"/>

        <Button
            android:id="@+id/buttonShowSQLite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Отримати дані напряму з SQLite"/>

        <Button
            android:id="@+id/buttonShowProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Отримати дані через ContentProvider"/>

        <Button
            android:id="@+id/buttonClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Очистити дані"/>

        <TextView
            android:id="@+id/textResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:paddingTop="20dp"/>

    </LinearLayout>
</ScrollView>